#!/usr/bin/env bash

echo "🔧 Fixing script permissions..."

for dir in cmd lib bin; do
  [ -d "$dir" ] || continue

  while IFS= read -r file; do
    if [[ ! -x "$file" ]]; then
      echo "⚠️ Making executable: $file"
      chmod +x "$file"
      git add "$file"   # 🔥 THIS is what you're missing
    fi
  done < <(find "$dir" -type f -name "*.sh")

done

# main entrypoints
[ -f "bin/doxo" ] && chmod +x bin/doxo && git add bin/doxo
[ -f "install.sh" ] && chmod +x install.sh && git add install.sh

echo "✅ Permissions fixed"
exit 0