#!/usr/bin/env bash

echo "🔧 Checking script permissions..."

# Ensure scripts are executable
for dir in cmd lib bin; do
  [ -d "$dir" ] || continue

  while IFS= read -r file; do
    if [[ ! -x "$file" ]]; then
      echo "⚠️ Making executable: $file"
      chmod +x "$file"
      git update-index --chmod=+x "$file"
    fi
  done < <(find "$dir" -type f -name "*.sh")

done

# Main CLI entrypoints
[ -f "bin/doxo" ] && chmod 755 bin/doxo
[ -f "install.sh" ] && chmod 755 install.sh

echo "✅ Pre-commit complete"
exit 0